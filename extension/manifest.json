{
  "manifest_version": 3,
  "name": "Anya",
  "version": "0.1.0",
  "description": "GitHub Copilot in your browser sidebar. Reads your tabs, drives Playwright, edits local code via a native bridge.",
  "author": "aasis21",
  "homepage_url": "https://github.com/aasis21/Anya",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Anya",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": { "default_path": "sidebar.html" },
  "background": { "service_worker": "background.js", "type": "module" },
  "permissions": ["sidePanel", "nativeMessaging", "tabs", "activeTab", "storage", "scripting", "bookmarks", "clipboardRead", "contextMenus", "history"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
